{
    "name": "mage-obsidian/module-modern-frontend",
    "description": "Modern frontend core for Magento 2 — replaces Luma/LESS/RequireJS with Vite, Tailwind CSS 4, Vue and native ESM while keeping Magento layouts, blocks and templates.",
    "keywords": [
        "magento",
        "magento2",
        "frontend",
        "vite",
        "vue",
        "tailwindcss",
        "theme"
    ],
    "homepage": "https://mage-obsidian.jeanmarcos.dev/",
    "support": {
        "issues": "https://github.com/mage-obsidian/module-modern-frontend/issues",
        "docs": "https://mage-obsidian.jeanmarcos.dev/",
        "source": "https://github.com/mage-obsidian/module-modern-frontend"
    },
    "authors": [
        {
            "name": "Jeanmarcos Juarez",
            "homepage": "https://github.com/jeanmarcos-dev"
        }
    ],
    "require": {
        "magento/product-community-edition": "^2.4.6",
        "justinrainbow/json-schema": "^5.2 || ^6.0"
    },
    "type": "magento2-module",
    "license": [
        "MIT"
    ],
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "MageObsidian\\ModernFrontend\\": "src/"
        }
    }
}
